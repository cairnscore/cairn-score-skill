#!/usr/bin/env bash
# Submit all queued Cairn ratings as one batch (chunked if > 100).
# Silent on success; removes the queue file. Errors to stderr, exit non-zero;
# the queue is rewritten to contain ONLY the unsent events so a retry doesn't
# double-submit chunks that already landed.
#
# Defensively normalizes task_tags, failure_modes, and metrics at submit time
# (cs-rate also normalizes at queue-write — this is belt-and-suspenders for
# entries written before normalization landed).
#
# Usage: scripts/cs-flush
#
# Requires CAIRN_API_KEY (auto-minted into ~/.cairn/keys/<host>.key
# on first run via mint-key.sh, which URL-scopes by default).

set -euo pipefail
command -v python3 >/dev/null || { echo "cs-flush: python3 required" >&2; exit 127; }

# Recursion guard: if we're inside a rater-spawned Claude Code session, don't
# flush the parent's queue.
[[ "${CAIRN_NESTED:-}" == "1" ]] && exit 0

: "${CAIRN_BASE_URL:=https://api.cairnscore.ai}"
: "${CAIRN_QUEUE:=$HOME/.cairn/queue.jsonl}"
# Don't default CAIRN_KEY_FILE here — mint-key.sh has its own URL-scoped
# default (~/.cairn/keys/<host>.key). Setting a legacy default here
# would override mint-key.sh's derivation via the exported env below.

# Resolve CAIRN_API_KEY via mint-key.sh, which owns the read-or-mint-and-
# persist critical section under fcntl.flock on ${CAIRN_KEY_FILE}.lock.
# Honors the same CAIRN_KEY_FILE / CAIRN_BASE_URL env vars so both
# surfaces coordinate on one file and one lock.
if [[ -z "${CAIRN_API_KEY:-}" ]]; then
  SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
  export CAIRN_KEY_FILE CAIRN_BASE_URL
  CAIRN_API_KEY=$(bash "$SCRIPT_DIR/mint-key.sh") || {
    echo "cs-flush: mint-key.sh failed; queue NOT submitted" >&2
    exit 1
  }
  export CAIRN_API_KEY
fi

# Take exclusive lock on the queue file so concurrent cs-rate appends don't
# race with our read/parse/POST/unlink cycle. Without this, an event written
# between our read and our unlink is silently lost. Same OFD-dup pattern as
# cs-rate and mint-key.sh; trap releases on EXIT, kernel on SIGKILL.
LOCK="${CAIRN_QUEUE}.lock"
mkdir -p "$(dirname "$LOCK")"
exec 9>"$LOCK"
trap 'exec 9>&-' EXIT
python3 -c 'import fcntl,sys; fcntl.flock(sys.stdin.fileno(), fcntl.LOCK_EX)' <&9

[[ -s "$CAIRN_QUEUE" ]] || exit 0

CAIRN_BASE_URL="$CAIRN_BASE_URL" \
CAIRN_API_KEY="$CAIRN_API_KEY" \
CAIRN_QUEUE="$CAIRN_QUEUE" \
python3 <<'PY'
import sys, os, json, re, math, time, urllib.request, urllib.error
from datetime import datetime, timezone

base = os.environ["CAIRN_BASE_URL"]
key = os.environ["CAIRN_API_KEY"]
queue_path = os.environ["CAIRN_QUEUE"]

# Opt-in JSONL side-log mirroring CAIRN_DEBUG_LOG in the MCP server.
# One line per chunk POST. Same explicit os.open(..., 0o600) pattern so the
# log is never observed at world-readable mode.
debug_path = os.environ.get("CAIRN_DEBUG_LOG")
debug_fd = None
if debug_path:
    debug_path = os.path.expanduser(debug_path)
    os.makedirs(os.path.dirname(debug_path) or ".", exist_ok=True)
    debug_fd = os.open(debug_path, os.O_WRONLY | os.O_CREAT | os.O_APPEND, 0o600)

def _log_chunk(chunk_idx, n_events, status, err_str, duration_ms):
    if debug_fd is None:
        return
    now = datetime.now(timezone.utc)
    entry = {
        "ts": now.strftime("%Y-%m-%dT%H:%M:%S.") + f"{now.microsecond // 1000:03d}Z",
        "method": "POST",
        "path": "/v1/scores/batch",
        "chunk_index": chunk_idx,
        "n_events": n_events,
        "status": status,
        "error": err_str,
        "duration_ms": duration_ms,
    }
    try:
        os.write(debug_fd, (json.dumps(entry, separators=(",", ":")) + "\n").encode("utf-8"))
    except Exception:
        pass

TAG_RE = re.compile(r"^[a-z][a-z0-9_]{0,63}$")

def normalize_tag(t):
    if not isinstance(t, str):
        return None
    s = t.strip().lower()
    s = re.sub(r"[^a-z0-9_]+", "_", s)
    s = s.strip("_")[:64]
    if not s or not s[0].isalpha():
        return None
    return s if TAG_RE.match(s) else None

def normalize_metric_value(v):
    """Metrics must be finite numbers. Coerce numeric strings; drop the rest."""
    if isinstance(v, bool):  # bool is int subclass in Python; not what TG wants
        return None
    if isinstance(v, (int, float)):
        if isinstance(v, float) and (math.isnan(v) or math.isinf(v)):
            return None
        return v
    if isinstance(v, str):
        try:
            num = float(v)
        except (ValueError, TypeError):
            return None
        if math.isnan(num) or math.isinf(num):
            return None
        return num
    return None

def normalize_event(ev):
    """Clean up tag and metric fields that might otherwise trip 422 validation."""
    if not isinstance(ev, dict):
        return ev
    for field in ("task_tags", "failure_modes"):
        if field in ev and isinstance(ev[field], list):
            out, seen = [], set()
            for t in ev[field]:
                n = normalize_tag(t)
                if n and n not in seen:
                    seen.add(n)
                    out.append(n)
            if out:
                ev[field] = out
            else:
                del ev[field]
    if "metrics" in ev and isinstance(ev["metrics"], dict):
        cleaned = {}
        for k, v in ev["metrics"].items():
            nv = normalize_metric_value(v)
            if nv is not None:
                cleaned[k] = nv
        if cleaned:
            ev["metrics"] = cleaned
        else:
            del ev["metrics"]
    return ev

with open(queue_path) as f:
    events = []
    dead_lines = []
    for line in f:
        line = line.strip()
        if not line:
            continue
        try:
            events.append(normalize_event(json.loads(line)))
        except json.JSONDecodeError:
            # Stash unparseable lines to queue.dead instead of silently
            # dropping — a partial cs-rate append (process killed mid-line,
            # disk full, etc.) is otherwise invisible.
            dead_lines.append(line)

if dead_lines:
    dead_path = queue_path + ".dead"
    with open(dead_path, "a") as f:
        for line in dead_lines:
            f.write(line + "\n")
    sys.stderr.write(f"cs-flush: dropped {len(dead_lines)} corrupted line(s) to {dead_path}\n")

if not events:
    os.unlink(queue_path)
    sys.exit(0)

def rewrite_queue(remaining):
    """Persist un-submitted events back to the queue file."""
    if not remaining:
        try:
            os.unlink(queue_path)
        except FileNotFoundError:
            pass
        return
    tmp_path = queue_path + ".tmp"
    with open(tmp_path, "w") as out:
        for ev in remaining:
            out.write(json.dumps(ev, separators=(",", ":")) + "\n")
    os.replace(tmp_path, queue_path)

CHUNK = 100
N = len(events)
for i in range(0, N, CHUNK):
    chunk = events[i:i + CHUNK]
    payload = json.dumps({"events": chunk}).encode()
    req = urllib.request.Request(
        f"{base}/v1/scores/batch",
        data=payload,
        headers={
            "X-Api-Key": key,
            "Content-Type": "application/json",
        },
        method="POST",
    )
    t0 = time.monotonic()
    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            body = resp.read()
            dur = round((time.monotonic() - t0) * 1000, 2)
            _log_chunk(i // CHUNK, len(chunk), resp.status, None, dur)
            if body:
                data = json.loads(body)
                if isinstance(data, dict) and "error" in data:
                    rewrite_queue(events[i:])
                    sys.exit(f"cs-flush: chunk {i // CHUNK} failed: {data['error']}")
    except urllib.error.HTTPError as e:
        dur = round((time.monotonic() - t0) * 1000, 2)
        body_str = e.read().decode(errors='replace')
        _log_chunk(i // CHUNK, len(chunk), e.code, f"HTTPError {e.code}", dur)
        rewrite_queue(events[i:])
        sys.exit(f"cs-flush: HTTP {e.code} on chunk {i // CHUNK}: {body_str}")
    except urllib.error.URLError as e:
        dur = round((time.monotonic() - t0) * 1000, 2)
        _log_chunk(i // CHUNK, len(chunk), None, f"URLError: {e.reason}", dur)
        rewrite_queue(events[i:])
        sys.exit(f"cs-flush: network error on chunk {i // CHUNK}: {e.reason}")

# All chunks succeeded.
os.unlink(queue_path)
# Sentinel for cs-doctor to surface "last successful flush" without
# parsing the debug log.
sentinel = os.path.join(os.path.dirname(queue_path) or ".", "last-flush")
try:
    with open(sentinel, "w") as f:
        f.write(str(int(time.time())))
except Exception:
    pass
PY
