#!/usr/bin/env bash
# Batch trust-score lookup for up to 100 entities. Refs come in as JSONL on
# stdin, one `{"type": "...", "external_id": "..."}` per line.
#
# Usage: scripts/cs-score-batch < refs.jsonl
#        printf '%s\n' '{"type":"data_source","external_id":"https://a.example.com"}' \
#                     '{"type":"capability","external_id":"mcp://weather-api"}' \
#          | scripts/cs-score-batch
#       → # n_refs=2 returned=2
#       → 0.78 0.83 data_source https://a.example.com
#       → 0.62 0.41 capability  mcp://weather-api
#
# Columns: <composite> <confidence> <type> <external_id>
# Unknown entities print 0.50 0.00 (the uninformed prior). Reads use no API key.

set -euo pipefail
command -v python3 >/dev/null || { echo "cs-score-batch: python3 required" >&2; exit 127; }

: "${CAIRN_BASE_URL:=https://api.cairnscore.ai}"

BODY=$(python3 -c '
import sys, json
refs = []
for line in sys.stdin:
    line = line.strip()
    if not line:
        continue
    try:
        ref = json.loads(line)
    except json.JSONDecodeError as e:
        sys.exit(f"cs-score-batch: bad JSONL line: {e}")
    if not isinstance(ref, dict) or "type" not in ref or "external_id" not in ref:
        sys.exit(f"cs-score-batch: each line must be a JSON object with type+external_id, got {ref!r}")
    refs.append({"type": ref["type"], "external_id": ref["external_id"]})
if not refs:
    sys.exit("cs-score-batch: no refs on stdin")
if len(refs) > 100:
    sys.exit(f"cs-score-batch: max 100 refs per call, got {len(refs)}")
print(json.dumps({"refs": refs}))
')

RESP=$(curl -sS -X POST "$CAIRN_BASE_URL/v1/score/batch" \
  -H "Content-Type: application/json" \
  -d "$BODY")

python3 -c '
import sys, json
data = json.loads(sys.stdin.read())
if isinstance(data, dict) and "error" in data:
    sys.exit("cs-score-batch: " + json.dumps(data["error"]))
if not isinstance(data, list):
    sys.exit(f"cs-score-batch: expected JSON array, got {type(data).__name__}")

n_refs = len(json.loads(sys.argv[1])["refs"])
print(f"# n_refs={n_refs} returned={len(data)}")
for item in data:
    cs = item.get("composite_score")
    cf = item.get("confidence")
    cs_str = f"{cs:.2f}" if isinstance(cs, (int, float)) else "?"
    cf_str = f"{cf:.2f}" if isinstance(cf, (int, float)) else "?"
    t = item.get("type", "?")
    ext = item.get("external_id", "?")
    print(f"{cs_str} {cf_str} {t:11} {ext}")
' "$BODY" <<< "$RESP"
