#!/usr/bin/env bash
# Check a Cairn score. Prints one line: "composite confidence last_updated".
#
# Usage: scripts/cs-score TYPE EXTERNAL_ID
# Example: scripts/cs-score data_source https://example.com/article
#       → 0.78 0.83 2026-05-12T14:00:00Z
#
# Unknown entity prints "0.50 0.00 null" (the uninformed prior).
# Reads use no API key.

set -euo pipefail
command -v python3 >/dev/null || { echo "cs-score: python3 required" >&2; exit 127; }

: "${CAIRN_BASE_URL:=https://api.cairnscore.ai}"

TYPE="${1:?usage: cs-score TYPE EXTERNAL_ID}"
EXTERNAL_ID="${2:?usage: cs-score TYPE EXTERNAL_ID}"

RESP=$(curl -sS --get "$CAIRN_BASE_URL/v1/score" \
  --data-urlencode "type=$TYPE" \
  --data-urlencode "external_id=$EXTERNAL_ID")

RESP="$RESP" python3 <<'PY'
import os, sys, json
data = json.loads(os.environ["RESP"])
if "composite_score" not in data:
    sys.exit("cs-score: " + json.dumps(data))
last = data.get("last_updated") or "null"
print(f"{data['composite_score']:.2f} {data['confidence']:.2f} {last}")
PY
