#!/usr/bin/env bash
# Read a tool-call briefing on stdin (JSON), use a Claude model to judge it
# per the cairn skill, and queue the resulting rating via scripts/cs-rate.
#
# Usage:
#   echo '<briefing-json>' | scripts/cs-judge-and-rate
#
# Briefing schema (stdin):
#   {
#     "entity": {"type": "data_source" | "capability", "external_id": "..."},
#     "tool":   "WebFetch" | "mcp://..." | ...,
#     "task":   "one-sentence description",
#     "request":  "...",
#     "response": "...",
#     "original_request_bytes":  <int>,
#     "original_response_bytes": <int>,
#     "outcome":  "success" | "partial" | "failure" | "unclear",
#     "direct_evidence": true | false
#   }
#
# Backends (CAIRN_RATER_BACKEND; default "auto" picks based on what's available):
#   "api"        — direct POST to api.anthropic.com (needs ANTHROPIC_API_KEY).
#                  Real $ charged per call (~$0.0003/rating cached), fast (~2s).
#                  Best for heavy use; doesn't touch your subscription allowance.
#   "claude-cli" — shell out to `claude -p`. Uses whatever auth Claude Code is
#                  logged in with (claude.ai subscription works). No API key
#                  needed and no additional $ charged — but each rating consumes
#                  from your subscription's usage allowance (same rolling-window
#                  quota as normal Claude work). Slower (~20s). Best when you
#                  don't want API-key setup and have headroom in your quota.
#   "auto"       — api if ANTHROPIC_API_KEY available, else claude-cli.
#
# Environment:
#   CAIRN_RATER_BACKEND      — "api" | "claude-cli" | "auto" (default "auto")
#   ANTHROPIC_API_KEY     — used by the api backend (env first, then key file)
#   CAIRN_ANTHROPIC_KEY_FILE — default ~/.cairn/anthropic-key
#   CAIRN_RATER_MODEL        — default claude-haiku-4-5-20251001
#   SKILL_DIR             — override skill directory (default: this script's parent)
#
# Recursion guard: sets CAIRN_NESTED=1 in the child env so the hook scripts
# bail out if they fire on tool calls the rater itself makes.
#
# On success: silent (rating queued via cs-rate). Token-usage line on stderr.
# On failure: stderr message, non-zero exit; nothing queued.

set -euo pipefail
command -v python3 >/dev/null || { echo "cs-judge-and-rate: python3 required" >&2; exit 127; }

: "${CAIRN_RATER_MODEL:=claude-haiku-4-5-20251001}"
: "${CAIRN_RATER_BACKEND:=auto}"
: "${CAIRN_ANTHROPIC_KEY_FILE:=$HOME/.cairn/anthropic-key}"

SKILL_DIR="${SKILL_DIR:-$(cd "$(dirname "$0")/.." && pwd)}"

BRIEFING=$(cat)
[[ -n "$BRIEFING" ]] || { echo "cs-judge-and-rate: empty briefing on stdin" >&2; exit 2; }

# Resolve ANTHROPIC_API_KEY (env → key file → empty).
# `read -r` (vs `$(<file)`) drops the trailing newline that text editors auto-
# append, otherwise the newline ends up inside the X-Api-Key header → 401.
if [[ -z "${ANTHROPIC_API_KEY:-}" ]] && [[ -s "$CAIRN_ANTHROPIC_KEY_FILE" ]]; then
  IFS= read -r ANTHROPIC_API_KEY < "$CAIRN_ANTHROPIC_KEY_FILE"
fi

# Resolve CAIRN_RATER_BACKEND when "auto".
if [[ "$CAIRN_RATER_BACKEND" == "auto" ]]; then
  if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
    CAIRN_RATER_BACKEND="api"
  elif command -v claude >/dev/null; then
    CAIRN_RATER_BACKEND="claude-cli"
  else
    echo "cs-judge-and-rate: no ANTHROPIC_API_KEY and no 'claude' on PATH" >&2
    exit 1
  fi
fi

# Build the system prompt (shared between backends).
PREAMBLE=$(cat <<'EOF'
You are a cairn rater. The user message contains a JSON briefing of one tool-call interaction. Use the skill content below to score it.

Anchor numerical dimensions (latency, cost, token_efficiency, context_efficiency) in the rationale with the underlying measurement.

The briefing includes original_request_bytes and original_response_bytes. Compare those to the length of request and response. If most content was preserved, use full weight (1.0). If a significant fraction was lost, downgrade weight proportionally — and only add response_truncated to failure_modes when the loss is heavy enough to plausibly mislead. Do not add response_truncated merely because the briefing is shorter than the original. If direct_evidence is false, drop weight to 0.5 or lower regardless of truncation.

EOF
)

SYS_PROMPT="$PREAMBLE"
for fname in SKILL.md references/rubric.md references/examples.md references/scoring-model.md; do
  fpath="$SKILL_DIR/$fname"
  if [[ -f "$fpath" ]]; then
    SYS_PROMPT+=$'\n=== '"$fname"$' ===\n'
    SYS_PROMPT+=$(<"$fpath")
    SYS_PROMPT+=$'\n'
  fi
done

# Output schema — used by both backends.
SCHEMA='{
  "type": "object",
  "required": ["reviewee", "score"],
  "additionalProperties": false,
  "properties": {
    "reviewee": {"type": "object", "required": ["type", "external_id"], "additionalProperties": false,
      "properties": {"type": {"type": "string", "enum": ["data_source", "capability"]},
                     "external_id": {"type": "string"}}},
    "score": {"type": "number", "minimum": 0, "maximum": 1},
    "weight": {"type": "number", "exclusiveMinimum": 0, "maximum": 1},
    "task": {"type": "string", "maxLength": 500},
    "rationale": {"type": "string", "maxLength": 2000},
    "dimensions": {"type": "object"},
    "failure_modes": {"type": "array", "items": {"type": "string"}, "maxItems": 10},
    "metrics": {"type": "object"},
    "task_tags": {"type": "array", "items": {"type": "string"}, "maxItems": 10}
  }
}'

case "$CAIRN_RATER_BACKEND" in
  api)
    [[ -n "${ANTHROPIC_API_KEY:-}" ]] || { echo "cs-judge-and-rate[api]: no ANTHROPIC_API_KEY available" >&2; exit 1; }

    BRIEFING="$BRIEFING" SYS_PROMPT="$SYS_PROMPT" SCHEMA="$SCHEMA" \
    CAIRN_RATER_MODEL="$CAIRN_RATER_MODEL" ANTHROPIC_API_KEY="$ANTHROPIC_API_KEY" \
    python3 <<'PY' | "$SKILL_DIR/scripts/cs-sanitize-rating" | "$SKILL_DIR/scripts/cs-rate"
import os, sys, json, urllib.request, urllib.error

briefing = json.loads(os.environ["BRIEFING"])
system_text = os.environ["SYS_PROMPT"]
schema = json.loads(os.environ["SCHEMA"])
api_key = os.environ["ANTHROPIC_API_KEY"]
model = os.environ["CAIRN_RATER_MODEL"]

tool_schema = {
    "name": "submit_rating",
    "description": "Submit one /v1/scores body.",
    "input_schema": schema,
}

body = {
    "model": model,
    "max_tokens": 1024,
    "system": [{"type": "text", "text": system_text, "cache_control": {"type": "ephemeral"}}],
    "tools": [tool_schema],
    "tool_choice": {"type": "tool", "name": "submit_rating"},
    "messages": [{"role": "user", "content": json.dumps(briefing, indent=2)}],
}

req = urllib.request.Request(
    "https://api.anthropic.com/v1/messages",
    data=json.dumps(body).encode(),
    headers={
        "x-api-key": api_key,
        "anthropic-version": "2023-06-01",
        "content-type": "application/json",
    },
    method="POST",
)

try:
    with urllib.request.urlopen(req, timeout=60) as resp:
        data = json.loads(resp.read())
except urllib.error.HTTPError as e:
    sys.exit(f"cs-judge-and-rate[api]: HTTP {e.code}: {e.read().decode(errors='replace')}")
except urllib.error.URLError as e:
    sys.exit(f"cs-judge-and-rate[api]: network error: {e.reason}")

rating = None
for block in data.get("content", []) or []:
    if block.get("type") == "tool_use" and block.get("name") == "submit_rating":
        rating = block.get("input")
        break

if rating is None:
    sys.exit("cs-judge-and-rate[api]: model did not call submit_rating\n" + json.dumps(data, indent=2))

usage = data.get("usage") or {}
print(
    f"cs-judge-and-rate[api]: in={usage.get('input_tokens', 0)} "
    f"cache_read={usage.get('cache_read_input_tokens', 0)} "
    f"cache_write={usage.get('cache_creation_input_tokens', 0)} "
    f"out={usage.get('output_tokens', 0)}",
    file=sys.stderr,
)
print(json.dumps(rating, separators=(",", ":")))
PY
    ;;

  claude-cli)
    command -v claude >/dev/null || { echo "cs-judge-and-rate[claude-cli]: 'claude' not on PATH" >&2; exit 1; }

    CAIRN_OUT=$(mktemp)
    trap 'rm -f "$CAIRN_OUT"' EXIT

    # --setting-sources "" / --disable-slash-commands / --tools "" strip Claude Code
    # context bloat (hooks, skills, plugins) so the rater session is minimal.
    # CAIRN_NESTED=1 stops our hooks from firing if any tool call leaks through.
    CAIRN_NESTED=1 claude -p \
      --model "$CAIRN_RATER_MODEL" \
      --setting-sources "" \
      --disable-slash-commands \
      --tools "" \
      --no-session-persistence \
      --system-prompt "$SYS_PROMPT" \
      --json-schema "$SCHEMA" \
      --output-format json \
      "$BRIEFING" \
      < /dev/null > "$CAIRN_OUT" 2>&1 || {
        echo "cs-judge-and-rate[claude-cli]: claude -p failed:" >&2
        cat "$CAIRN_OUT" >&2
        exit 1
      }

    CAIRN_OUT="$CAIRN_OUT" python3 <<'PY' | "$SKILL_DIR/scripts/cs-sanitize-rating" | "$SKILL_DIR/scripts/cs-rate"
import os, sys, json

with open(os.environ["CAIRN_OUT"]) as f:
    raw = f.read()

try:
    wrap = json.loads(raw)
except json.JSONDecodeError as e:
    sys.exit(f"cs-judge-and-rate[claude-cli]: could not parse claude -p output: {e}\n{raw[:500]}")

rating = wrap.get("structured_output")
if not rating:
    result_text = (wrap.get("result") or "")[:200]
    sys.exit(f"cs-judge-and-rate[claude-cli]: no structured_output in response. result={result_text!r}")

usage = wrap.get("usage") or {}
cost = wrap.get("total_cost_usd") or 0
# Note: the claude-cli backend doesn't actually charge $ — this is the
# imputed API-equivalent cost. Real billing is your subscription's usage
# allowance, which the input/cache_read/cache_write/out counts approximate.
print(
    f"cs-judge-and-rate[claude-cli]: quota_equiv=${cost:.4f} "
    f"input={usage.get('input_tokens', 0)} "
    f"cache_read={usage.get('cache_read_input_tokens', 0)} "
    f"cache_write={usage.get('cache_creation_input_tokens', 0)} "
    f"out={usage.get('output_tokens', 0)}",
    file=sys.stderr,
)
print(json.dumps(rating, separators=(",", ":")))
PY
    ;;

  *)
    echo "cs-judge-and-rate: unknown CAIRN_RATER_BACKEND='$CAIRN_RATER_BACKEND' (want api|claude-cli|auto)" >&2
    exit 2
    ;;
esac
