#!/usr/bin/env bash
# Queue a TrustGraph rating for batch submission. Silent on success.
#
# Usage: echo '<json>' | scripts/tg-rate
#   The JSON is a valid POST /v1/scores body:
#     {"reviewee": {"type": "...", "external_id": "..."}, "score": 0.8, ...}
#   See references/rubric.md for the full field list.
#
# Appends one JSON line to $TRUSTGRAPH_QUEUE (default ~/.trustgraph/queue.jsonl).
#
# Normalizations applied (silent — avoids the all-or-nothing 422 trap at flush):
#   task_tags, failure_modes : coerced to snake_case ^[a-z][a-z0-9_]{0,63}$; bad ones dropped
#   metrics                  : non-numeric values dropped (rater sometimes emits
#                              strings like "execution_status":"success" or "latency_unit":"seconds"
#                              despite the schema requiring finite floats)
#
# Use scripts/tg-flush at session end to submit the queue as one batch.
#
# Does not require TRUSTGRAPH_API_KEY (that's only needed at flush time).

set -euo pipefail
command -v python3 >/dev/null || { echo "tg-rate: python3 required" >&2; exit 127; }

: "${TRUSTGRAPH_QUEUE:=$HOME/.trustgraph/queue.jsonl}"

mkdir -p "$(dirname "$TRUSTGRAPH_QUEUE")"

# Read stdin BEFORE the heredoc — heredocs replace stdin.
INPUT=$(cat)

# Validate, normalize, re-emit compactly.
INPUT="$INPUT" python3 <<'PY' >> "$TRUSTGRAPH_QUEUE"
import os, sys, json, re, math

TAG_RE = re.compile(r"^[a-z][a-z0-9_]{0,63}$")

def normalize_tag(t):
    if not isinstance(t, str):
        return None
    s = t.strip().lower()
    s = re.sub(r"[^a-z0-9_]+", "_", s)
    s = s.strip("_")[:64]
    if not s:
        return None
    if not s[0].isalpha():
        return None
    return s if TAG_RE.match(s) else None

def normalize_tag_list(lst):
    if not isinstance(lst, list):
        return lst
    out, seen = [], set()
    for t in lst:
        n = normalize_tag(t)
        if n and n not in seen:
            seen.add(n)
            out.append(n)
    return out

def normalize_metric_value(v):
    """Metrics must be finite numbers. Coerce numeric strings; drop the rest."""
    if isinstance(v, bool):
        return None
    if isinstance(v, (int, float)):
        if isinstance(v, float) and (math.isnan(v) or math.isinf(v)):
            return None
        return v
    if isinstance(v, str):
        try:
            num = float(v)
        except (ValueError, TypeError):
            return None
        if math.isnan(num) or math.isinf(num):
            return None
        return num
    return None

try:
    obj = json.loads(os.environ["INPUT"])
except json.JSONDecodeError as e:
    sys.exit(f"tg-rate: invalid JSON on stdin: {e}")
if not isinstance(obj, dict):
    sys.exit("tg-rate: stdin must be a JSON object")
if "reviewee" not in obj or "score" not in obj:
    sys.exit("tg-rate: body must include 'reviewee' and 'score'")

if "task_tags" in obj:
    cleaned = normalize_tag_list(obj["task_tags"])
    if cleaned:
        obj["task_tags"] = cleaned
    else:
        del obj["task_tags"]

if "failure_modes" in obj:
    cleaned = normalize_tag_list(obj["failure_modes"])
    if cleaned:
        obj["failure_modes"] = cleaned
    else:
        del obj["failure_modes"]

if "metrics" in obj and isinstance(obj["metrics"], dict):
    cleaned = {}
    for k, v in obj["metrics"].items():
        nv = normalize_metric_value(v)
        if nv is not None:
            cleaned[k] = nv
    if cleaned:
        obj["metrics"] = cleaned
    else:
        del obj["metrics"]

print(json.dumps(obj, separators=(",", ":")))
PY
