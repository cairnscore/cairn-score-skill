#!/usr/bin/env bash
# Submit all queued TrustGraph ratings as one batch (chunked if > 100).
# Silent on success; removes the queue file. Errors to stderr, exit non-zero;
# the queue is rewritten to contain ONLY the unsent events so a retry doesn't
# double-submit chunks that already landed.
#
# Defensively normalizes task_tags, failure_modes, and metrics at submit time
# (tg-rate also normalizes at queue-write — this is belt-and-suspenders for
# entries written before normalization landed).
#
# Usage: scripts/tg-flush
#
# Requires TRUSTGRAPH_API_KEY (auto-minted into ~/.trustgraph/api-key on first run).

set -euo pipefail
command -v python3 >/dev/null || { echo "tg-flush: python3 required" >&2; exit 127; }

# Recursion guard: if we're inside a rater-spawned Claude Code session, don't
# flush the parent's queue.
[[ "${TRUSTGRAPH_NESTED:-}" == "1" ]] && exit 0

: "${TRUSTGRAPH_BASE_URL:=https://mep39camvm.us-east-1.awsapprunner.com}"
: "${TRUSTGRAPH_QUEUE:=$HOME/.trustgraph/queue.jsonl}"
: "${TRUSTGRAPH_KEY_FILE:=$HOME/.trustgraph/api-key}"

# Resolve TRUSTGRAPH_API_KEY: env → persisted key file → mint + persist.
if [[ -z "${TRUSTGRAPH_API_KEY:-}" ]]; then
  if [[ -s "$TRUSTGRAPH_KEY_FILE" ]]; then
    TRUSTGRAPH_API_KEY=$(<"$TRUSTGRAPH_KEY_FILE")
  else
    SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
    TRUSTGRAPH_API_KEY=$(bash "$SCRIPT_DIR/mint-key.sh")
    mkdir -p "$(dirname "$TRUSTGRAPH_KEY_FILE")"
    umask 077
    printf '%s\n' "$TRUSTGRAPH_API_KEY" > "$TRUSTGRAPH_KEY_FILE"
    chmod 600 "$TRUSTGRAPH_KEY_FILE"
  fi
  export TRUSTGRAPH_API_KEY
fi

[[ -s "$TRUSTGRAPH_QUEUE" ]] || exit 0

TRUSTGRAPH_BASE_URL="$TRUSTGRAPH_BASE_URL" \
TRUSTGRAPH_API_KEY="$TRUSTGRAPH_API_KEY" \
TRUSTGRAPH_QUEUE="$TRUSTGRAPH_QUEUE" \
python3 <<'PY'
import sys, os, json, re, math, urllib.request, urllib.error

base = os.environ["TRUSTGRAPH_BASE_URL"]
key = os.environ["TRUSTGRAPH_API_KEY"]
queue_path = os.environ["TRUSTGRAPH_QUEUE"]

TAG_RE = re.compile(r"^[a-z][a-z0-9_]{0,63}$")

def normalize_tag(t):
    if not isinstance(t, str):
        return None
    s = t.strip().lower()
    s = re.sub(r"[^a-z0-9_]+", "_", s)
    s = s.strip("_")[:64]
    if not s or not s[0].isalpha():
        return None
    return s if TAG_RE.match(s) else None

def normalize_metric_value(v):
    """Metrics must be finite numbers. Coerce numeric strings; drop the rest."""
    if isinstance(v, bool):  # bool is int subclass in Python; not what TG wants
        return None
    if isinstance(v, (int, float)):
        if isinstance(v, float) and (math.isnan(v) or math.isinf(v)):
            return None
        return v
    if isinstance(v, str):
        try:
            num = float(v)
        except (ValueError, TypeError):
            return None
        if math.isnan(num) or math.isinf(num):
            return None
        return num
    return None

def normalize_event(ev):
    """Clean up tag and metric fields that might otherwise trip 422 validation."""
    if not isinstance(ev, dict):
        return ev
    for field in ("task_tags", "failure_modes"):
        if field in ev and isinstance(ev[field], list):
            out, seen = [], set()
            for t in ev[field]:
                n = normalize_tag(t)
                if n and n not in seen:
                    seen.add(n)
                    out.append(n)
            if out:
                ev[field] = out
            else:
                del ev[field]
    if "metrics" in ev and isinstance(ev["metrics"], dict):
        cleaned = {}
        for k, v in ev["metrics"].items():
            nv = normalize_metric_value(v)
            if nv is not None:
                cleaned[k] = nv
        if cleaned:
            ev["metrics"] = cleaned
        else:
            del ev["metrics"]
    return ev

with open(queue_path) as f:
    events = []
    for line in f:
        line = line.strip()
        if not line:
            continue
        try:
            events.append(normalize_event(json.loads(line)))
        except json.JSONDecodeError:
            # Drop unparseable lines silently; they would have failed validation anyway.
            continue

if not events:
    os.unlink(queue_path)
    sys.exit(0)

def rewrite_queue(remaining):
    """Persist un-submitted events back to the queue file."""
    if not remaining:
        try:
            os.unlink(queue_path)
        except FileNotFoundError:
            pass
        return
    tmp_path = queue_path + ".tmp"
    with open(tmp_path, "w") as out:
        for ev in remaining:
            out.write(json.dumps(ev, separators=(",", ":")) + "\n")
    os.replace(tmp_path, queue_path)

CHUNK = 100
N = len(events)
for i in range(0, N, CHUNK):
    chunk = events[i:i + CHUNK]
    payload = json.dumps({"events": chunk}).encode()
    req = urllib.request.Request(
        f"{base}/v1/scores/batch",
        data=payload,
        headers={
            "X-Api-Key": key,
            "Content-Type": "application/json",
        },
        method="POST",
    )
    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            body = resp.read()
            if body:
                data = json.loads(body)
                if isinstance(data, dict) and "error" in data:
                    rewrite_queue(events[i:])
                    sys.exit(f"tg-flush: chunk {i // CHUNK} failed: {data['error']}")
    except urllib.error.HTTPError as e:
        rewrite_queue(events[i:])
        sys.exit(f"tg-flush: HTTP {e.code} on chunk {i // CHUNK}: {e.read().decode(errors='replace')}")
    except urllib.error.URLError as e:
        rewrite_queue(events[i:])
        sys.exit(f"tg-flush: network error on chunk {i // CHUNK}: {e.reason}")

# All chunks succeeded.
os.unlink(queue_path)
PY
